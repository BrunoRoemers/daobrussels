---
import type { CollectionEntry } from 'astro:content';

interface Props {
  pod: CollectionEntry<'pods'>;
}

const { pod } = Astro.props;
const { title, description, status, links } = pod.data;

const statusColors: Record<string, string> = {
  active: 'bg-green-100 text-green-800',
  proposed: 'bg-yellow-100 text-yellow-800',
  paused: 'bg-gray-100 text-gray-600',
  completed: 'bg-blue-100 text-blue-800',
};
---

<div class="mb-8">
  <div class="flex items-center gap-3 mb-2">
    <span class:list={['text-xs px-2.5 py-1 rounded-full font-medium capitalize', statusColors[status]]}>
      {status}
    </span>
  </div>
  <h1 class="text-3xl font-semibold text-gray-900">{title}</h1>
  <p class="mt-3 text-lg text-gray-700 leading-relaxed">{description}</p>

  {links.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {links.map(({ label, url }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm text-dao-green border border-dao-light/50 px-3 py-1 rounded-full hover:bg-dao-light/20 transition-colors"
        >
          {label}
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      ))}
    </div>
  )}
</div>
<hr class="border-gray-200 mb-8" />
