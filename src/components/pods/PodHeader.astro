---
/**
 * PodHeader — header for the pod detail page. Mono caps eyebrow, big display
 * title, description, status chip + external link chips.
 */
import type { CollectionEntry } from 'astro:content';
import Glyph from '../marks/Glyph.astro';
import { glyphForSeed } from '../../lib/glyphs';

interface Props {
  pod: CollectionEntry<'pods'>;
}
const { pod } = Astro.props;
const { title, description, status, links } = pod.data;
const kind = glyphForSeed(pod.slug);
---

<div class="border-b border-ink py-3 px-1 font-mono text-xs tracking-widercaps">
  <a href="/pods" class="opacity-60 hover:opacity-100">PODS</a>
  <span class="opacity-40 mx-1">/</span>
  <span class="text-ink">{title.toUpperCase()}</span>
</div>

<header class="py-8 md:py-12">
  <div class="flex items-start gap-5 mb-6">
    <Glyph kind={kind} size={72} class="mt-1" />
    <div>
      <div class="mono-label opacity-60">POD · {status.toUpperCase()}</div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-medium tracking-[-0.03em] leading-[0.95] m-0 mt-1">
        {title}
      </h1>
    </div>
  </div>

  <p class="text-base md:text-lg leading-relaxed max-w-2xl text-muted">{description}</p>

  {links.length > 0 && (
    <div class="mt-6 flex flex-wrap gap-2">
      {links.map(({ label, url }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="chip hover:bg-ink hover:text-paper transition-colors inline-flex items-center gap-1.5"
        >
          {label.toUpperCase()} ↗
        </a>
      ))}
    </div>
  )}
</header>
