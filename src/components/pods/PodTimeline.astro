---
/**
 * PodTimeline — chronological list of meeting appearances for a pod, rendered
 * as a hard-bordered table. Each row has a date stamp on the left.
 */
import type { CollectionEntry } from 'astro:content';
import { formatShortDate } from '../../lib/content';

interface Props {
  events: CollectionEntry<'events'>[];
}

const { events } = Astro.props;
const sorted = [...events].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

{sorted.length > 0 && (
  <section class="mt-12">
    <div class="mono-label-lg mb-5">◇ MEETING APPEARANCES</div>
    <div class="border-2 border-ink">
      {sorted.map((event, i) => (
        <a
          href={`/events/${event.slug}`}
          class:list={[
            'grid grid-cols-[110px_1fr] sm:grid-cols-[140px_1fr] gap-4 px-4 sm:px-5 py-4',
            'hover:bg-ink hover:text-paper transition-colors',
            i < sorted.length - 1 ? 'border-b border-ink' : '',
          ]}
        >
          <div class="font-mono text-xs tracking-widercaps">
            {formatShortDate(event.data.date).toUpperCase()}
          </div>
          <div>
            <div class="font-medium text-base">{event.data.title}</div>
            {event.data.summary && (
              <p class="text-sm opacity-80 mt-0.5 line-clamp-1">{event.data.summary}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
)}
