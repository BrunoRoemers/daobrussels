---
import type { CollectionEntry } from 'astro:content';
import { formatShortDate } from '../../lib/content';

interface Props {
  events: CollectionEntry<'events'>[];
}

const { events } = Astro.props;
const sorted = [...events].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

{sorted.length > 0 && (
  <div class="mt-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Meeting appearances</h2>
    <ol class="relative border-l border-gray-200 space-y-6 pl-6">
      {sorted.map((event) => (
        <li class="relative">
          <span class="absolute -left-[25px] w-3 h-3 rounded-full bg-dao-green border-2 border-white top-1"></span>
          <time
            datetime={event.data.date.toISOString()}
            class="text-xs font-mono text-dao-green font-medium uppercase tracking-wide"
          >
            {formatShortDate(event.data.date)}
          </time>
          <a
            href={`/events/${event.slug}`}
            class="block mt-0.5 font-medium text-gray-900 hover:text-dao-green transition-colors"
          >
            {event.data.title}
          </a>
          {event.data.summary && (
            <p class="mt-1 text-sm text-gray-500">{event.data.summary}</p>
          )}
        </li>
      ))}
    </ol>
  </div>
)}
