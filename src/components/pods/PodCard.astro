---
/**
 * PodCard — grid cell card. The dominant visual is the Glyph; the cell is
 * a hard rectangle with a single black rule between siblings (handled by the
 * parent grid). The whole cell is clickable.
 */
import type { CollectionEntry } from 'astro:content';
import Glyph from '../marks/Glyph.astro';
import { glyphForSeed } from '../../lib/glyphs';

interface Props {
  pod: CollectionEntry<'pods'>;
}
const { pod } = Astro.props;
const { title, description, status, events } = pod.data;
const kind = glyphForSeed(pod.slug);
---

<a
  href={`/pods/${pod.slug}`}
  class="group flex flex-col justify-between p-7 min-h-[200px] hover:bg-ink hover:text-paper transition-colors"
>
  <div>
    <Glyph kind={kind} size={48} color="currentColor" />
    <h4 class="text-xl sm:text-2xl font-medium tracking-tight mt-5 mb-2 leading-tight">{title}</h4>
    <p class="text-sm leading-snug opacity-80 line-clamp-3">{description}</p>
  </div>
  <div class="flex justify-between items-center mt-5 font-mono text-[11px] tracking-widercaps">
    <span>{events.length} {events.length === 1 ? 'EVENT' : 'EVENTS'} · {status.toUpperCase()}</span>
    <span>OPEN →</span>
  </div>
</a>
