---
import type { CollectionEntry } from 'astro:content';

interface Props {
  pod: CollectionEntry<'pods'>;
}

const { pod } = Astro.props;
const { title, description, status, events } = pod.data;

const statusColors: Record<string, string> = {
  active: 'bg-green-100 text-green-800',
  proposed: 'bg-yellow-100 text-yellow-800',
  paused: 'bg-gray-100 text-gray-600',
  completed: 'bg-blue-100 text-blue-800',
};
---

<a
  href={`/pods/${pod.slug}`}
  class="block group rounded-xl border border-gray-200 bg-white p-5 hover:border-dao-green hover:shadow-sm transition-all"
>
  <div class="flex items-start justify-between gap-3 mb-2">
    <h2 class="font-semibold text-gray-900 group-hover:text-dao-dark transition-colors">
      {title}
    </h2>
    <span class:list={['shrink-0 text-xs px-2 py-0.5 rounded-full font-medium capitalize', statusColors[status]]}>
      {status}
    </span>
  </div>
  <p class="text-sm text-gray-600 leading-relaxed line-clamp-3">{description}</p>
  {events.length > 0 && (
    <p class="mt-3 text-xs text-gray-400">
      Active in {events.length} meeting{events.length !== 1 ? 's' : ''}
    </p>
  )}
</a>
