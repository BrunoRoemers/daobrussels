---
/**
 * Glyph — the geometric vocabulary of DAO Brussels.
 *
 * Every avatar, section eyebrow, pod marker, decorative shape on the site uses
 * one of these primitives. Keep this file the single source of truth for the
 * shape language; never inline a `<svg>` for one of these kinds elsewhere.
 *
 * Usage:
 *   <Glyph kind="circle" size={64} />
 *   <Glyph kind="ring" size={300} color="#fafaf7" />
 *   <Glyph kind="diamond" size={140} filled={false} />
 */

import type { GlyphKind } from './types';
export type { GlyphKind };

interface Props {
  kind: GlyphKind;
  size?: number;
  color?: string;
  filled?: boolean;
  class?: string;
  /** Optional aria-label; if omitted the glyph is treated as decorative. */
  label?: string;
}

const {
  kind,
  size = 64,
  color = '#0a0a0a',
  filled = true,
  class: className = '',
  label,
} = Astro.props;

// Stable per-render id so multiple <Glyph kind="hatch" /> on one page don't
// collide on their <pattern> id.
const uid = Math.random().toString(36).slice(2, 8);
const ariaProps = label
  ? { role: 'img', 'aria-label': label }
  : { 'aria-hidden': 'true' };
---

{kind === 'circle' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <circle cx="50" cy="50" r="48" fill={filled ? color : 'none'} stroke={color} stroke-width="2" />
  </svg>
)}

{kind === 'ring' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <circle cx="50" cy="50" r="40" fill="none" stroke={color} stroke-width="6" />
  </svg>
)}

{kind === 'dot-grid' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    {Array.from({ length: 5 }).map((_, r) =>
      Array.from({ length: 5 }).map((_, c) => (
        <circle cx={10 + c * 20} cy={10 + r * 20} r="3" fill={color} />
      ))
    )}
  </svg>
)}

{kind === 'square' && (
  <div
    class={`block shrink-0 ${className}`}
    style={{
      width: `${size}px`,
      height: `${size}px`,
      background: filled ? color : 'transparent',
      border: `2px solid ${color}`,
    }}
    {...ariaProps}
  />
)}

{kind === 'diamond' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <rect x="20" y="20" width="60" height="60" transform="rotate(45 50 50)" fill={filled ? color : 'none'} stroke={color} stroke-width="2" />
  </svg>
)}

{kind === 'triangle' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <polygon points="50,6 94,90 6,90" fill={filled ? color : 'none'} stroke={color} stroke-width="2" />
  </svg>
)}

{kind === 'half' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <path d="M 50 2 A 48 48 0 0 1 50 98 Z" fill={color} />
    <circle cx="50" cy="50" r="48" fill="none" stroke={color} stroke-width="2" />
  </svg>
)}

{kind === 'quad' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <line x1="50" y1="0" x2="50" y2="100" stroke={color} stroke-width="2" />
    <line x1="0" y1="50" x2="100" y2="50" stroke={color} stroke-width="2" />
    <circle cx="50" cy="50" r="48" fill="none" stroke={color} stroke-width="2" />
  </svg>
)}

{kind === 'plus' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <line x1="50" y1="10" x2="50" y2="90" stroke={color} stroke-width="8" />
    <line x1="10" y1="50" x2="90" y2="50" stroke={color} stroke-width="8" />
  </svg>
)}

{kind === 'hatch' && (
  <svg viewBox="0 0 100 100" width={size} height={size} class={`block shrink-0 ${className}`} {...ariaProps}>
    <defs>
      <pattern id={`hatch-${uid}`} width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
        <line x1="0" y1="0" x2="0" y2="6" stroke={color} stroke-width="2" />
      </pattern>
    </defs>
    <circle cx="50" cy="50" r="48" fill={`url(#hatch-${uid})`} stroke={color} stroke-width="2" />
  </svg>
)}
