---
/**
 * EventBigCard — the headline "Next Assembly" card on the home page.
 * Three-column grid (date stamp · body · meta) on desktop, stacks on mobile.
 *
 * Tags are derived from any pods the event references (so we never display
 * invented "#governance #gardening" etc.). Attendee counts are intentionally
 * absent until we have a real RSVP source — "RSVP →" is the call to action.
 */
import type { CollectionEntry } from 'astro:content';
import { getEntries } from 'astro:content';
import Glyph from '../marks/Glyph.astro';

interface Props {
  event: CollectionEntry<'events'>;
  /** 1-based chronological number for this assembly. */
  assemblyNo?: number;
}
const { event, assemblyNo } = Astro.props;
const { title, date, location, summary, pods: podRefs } = event.data;
const pods = await getEntries(podRefs);

const day = String(date.getUTCDate()).padStart(2, '0');
const month = date.toLocaleString('en-GB', { month: 'short', timeZone: 'UTC' }).toUpperCase();
const year = String(date.getUTCFullYear() % 100).padStart(2, '0');
const weekday = date.toLocaleString('en-GB', { weekday: 'short', timeZone: 'UTC' }).toUpperCase();
---

<div class="border-2 border-ink grid grid-cols-1 md:grid-cols-[180px_1fr_220px]">
  <!-- Date stamp -->
  <div class="bg-ink text-paper p-6 sm:p-7 flex md:flex-col items-center md:items-start justify-between gap-4 md:border-r border-ink">
    <div>
      <div class="font-mono text-[11px] opacity-60 tracking-widercaps">{weekday}</div>
      <div class="text-6xl md:text-[96px] leading-none font-medium tracking-[-0.05em]">{day}</div>
      <div class="font-mono text-[13px] mt-1">{month} · {year}</div>
    </div>
    <Glyph kind="circle" size={28} color="#fafaf7" class="hidden md:block" />
  </div>

  <!-- Body -->
  <div class="p-6 sm:p-7 md:border-r border-ink border-t md:border-t-0">
    <div class="font-mono text-[11px] tracking-widercaps mb-3">
      {assemblyNo ? `ASSEMBLY №${assemblyNo}` : 'ASSEMBLY'}
    </div>
    <h3 class="text-2xl sm:text-3xl font-medium tracking-[-0.02em] leading-tight m-0">{title}</h3>
    {summary && <p class="mt-3 text-sm sm:text-base leading-relaxed text-muted">{summary}</p>}
    {pods.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {pods.map((p) => <span class="chip">◇ {p.data.title}</span>)}
      </div>
    )}
  </div>

  <!-- Meta + RSVP -->
  <div class="p-6 sm:p-7 flex flex-col justify-between gap-4 border-t md:border-t-0 border-ink">
    <div>
      <div class="mono-label opacity-60 mb-1">DOORS</div>
      <div class="font-mono text-xs">19:30 — late</div>
      {location && (
        <>
          <div class="mono-label opacity-60 mb-1 mt-3">WHERE</div>
          <div class="font-mono text-xs leading-relaxed">{location}</div>
        </>
      )}
    </div>
    <a href={`/events/${event.slug}`} class="btn-ink py-3 px-4 text-center w-full">RSVP →</a>
  </div>
</div>
