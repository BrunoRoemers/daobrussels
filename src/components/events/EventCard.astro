---
import type { CollectionEntry } from 'astro:content';
import { formatShortDate } from '../../lib/content';

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const { title, date, location, summary, pods } = event.data;
---

<a
  href={`/events/${event.slug}`}
  class="block group rounded-xl border border-gray-200 bg-white p-5 hover:border-dao-green hover:shadow-sm transition-all"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <time
        datetime={date.toISOString()}
        class="text-xs font-mono text-dao-green font-medium uppercase tracking-wide"
      >
        {formatShortDate(date)}
      </time>
      <h2 class="mt-1 font-semibold text-gray-900 group-hover:text-dao-dark transition-colors">
        {title}
      </h2>
      {location && (
        <p class="mt-0.5 text-sm text-gray-500">{location}</p>
      )}
      {summary && (
        <p class="mt-2 text-sm text-gray-600 leading-relaxed">{summary}</p>
      )}
    </div>
    {pods.length > 0 && (
      <span class="shrink-0 text-xs bg-dao-light/20 text-dao-dark px-2 py-1 rounded-full font-medium">
        {pods.length} pod{pods.length !== 1 ? 's' : ''}
      </span>
    )}
  </div>
</a>
