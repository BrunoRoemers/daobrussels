---
/**
 * EventCard — list-item card for an event.
 * Black-rule grid layout: a hard-edged date stamp on the left, content body
 * on the right. Stacks on mobile.
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  event: CollectionEntry<'events'>;
  /** 1-based chronological number for this assembly. */
  assemblyNo?: number;
}
const { event, assemblyNo } = Astro.props;
const { title, date, location, summary, pods } = event.data;

const day = String(date.getUTCDate()).padStart(2, '0');
const month = date.toLocaleString('en-GB', { month: 'short', timeZone: 'UTC' }).toUpperCase();
const year = String(date.getUTCFullYear() % 100).padStart(2, '0');
const weekday = date.toLocaleString('en-GB', { weekday: 'short', timeZone: 'UTC' }).toUpperCase();
---

<a
  href={`/events/${event.slug}`}
  class="group block border-2 border-ink hover:bg-ink hover:text-paper transition-colors"
>
  <div class="grid grid-cols-[88px_1fr] sm:grid-cols-[120px_1fr]">
    <!-- Date stamp -->
    <div class="bg-ink text-paper p-4 sm:p-5 flex flex-col justify-between border-r-2 border-ink group-hover:bg-paper group-hover:text-ink transition-colors">
      <div>
        <div class="font-mono text-[10px] tracking-widercaps opacity-60">{weekday}</div>
        <div class="text-4xl sm:text-5xl font-medium tracking-[-0.04em] leading-none mt-1">{day}</div>
        <div class="font-mono text-[11px] mt-1">{month} · {year}</div>
      </div>
    </div>

    <!-- Body -->
    <div class="p-4 sm:p-6 flex flex-col gap-2">
      {assemblyNo && (
        <div class="font-mono text-[11px] opacity-60 tracking-widercaps">ASSEMBLY №{assemblyNo}</div>
      )}
      <h3 class="text-lg sm:text-xl font-medium tracking-tight leading-snug">{title}</h3>
      {location && <div class="font-mono text-[11px] opacity-60 tracking-widercaps line-clamp-1">{location.toUpperCase()}</div>}
      {summary && <p class="text-sm leading-relaxed line-clamp-2 opacity-80">{summary}</p>}
      {pods.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-1">
          <span class="chip group-hover:border-paper">{pods.length} pod{pods.length !== 1 ? 's' : ''}</span>
        </div>
      )}
    </div>
  </div>
</a>
