---
interface Props {
  images: string[];
  alt: string;
  /** Chronological assembly number, e.g. 47 → "FIG. 047". */
  number?: number;
  /** Optional small label printed next to the FIG. counter, e.g. the title. */
  caption?: string;
}

const { images, alt, number, caption } = Astro.props;
const fig = number ? String(number).padStart(3, '0') : null;
const multi = images.length > 1;
const id = `cover-${Math.random().toString(36).slice(2, 8)}`;
---

<figure class="my-8 md:my-10" id={id}>
  <div class="relative border-2 border-ink overflow-hidden bg-ink group">
    {images.map((src, i) => (
      <img
        src={src}
        alt={alt}
        loading={i === 0 ? 'eager' : 'lazy'}
        decoding="async"
        data-index={i}
        class:list={[
          'block w-full h-auto aspect-[16/9] object-cover',
          '[filter:grayscale(0.7)_contrast(1.05)] hover:[filter:grayscale(0)_contrast(1)] transition-[filter] duration-500',
          i !== 0 && 'hidden',
        ]}
      />
    ))}

    {multi && (
      <div class="absolute inset-y-0 left-0 right-0 flex items-center justify-between px-3 pointer-events-none">
        <button
          data-prev
          aria-label="Previous image"
          class="pointer-events-auto font-mono text-xs bg-paper border border-ink px-2 py-1 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-ink hover:text-paper"
        >← PREV</button>
        <button
          data-next
          aria-label="Next image"
          class="pointer-events-auto font-mono text-xs bg-paper border border-ink px-2 py-1 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-ink hover:text-paper"
        >NEXT →</button>
      </div>
    )}
  </div>

  <figcaption class="mt-3 flex items-baseline justify-between gap-4 font-mono text-[11px] tracking-widercaps uppercase">
    <span>
      {fig && <>FIG. {fig}</>}
      {multi && <span data-counter class="opacity-60 ml-2">1 / {images.length}</span>}
    </span>
    {caption && <span class="opacity-60 truncate">{caption}</span>}
  </figcaption>
</figure>

{multi && (
  <script define:vars={{ id, total: images.length }}>
    const fig = document.getElementById(id);
    const imgs = fig.querySelectorAll('img[data-index]');
    const counter = fig.querySelector('[data-counter]');
    let current = 0;

    function show(n) {
      imgs[current].classList.add('hidden');
      current = (n + total) % total;
      imgs[current].classList.remove('hidden');
      counter.textContent = `${current + 1} / ${total}`;
    }

    fig.querySelector('[data-prev]').addEventListener('click', () => show(current - 1));
    fig.querySelector('[data-next]').addEventListener('click', () => show(current + 1));
  </script>
)}
