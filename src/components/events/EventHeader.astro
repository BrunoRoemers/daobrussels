---
/**
 * EventHeader — the page header for an event detail page. Renders the
 * crumbs, mono assembly id, large display title, and summary.
 */
import type { CollectionEntry } from 'astro:content';
import { getEntries } from 'astro:content';
import Glyph from '../marks/Glyph.astro';
import { formatDate } from '../../lib/content';

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const { title, date, location, locationUrl, summary, pods: podRefs } = event.data;
const pods = await getEntries(podRefs);

const month = date.toLocaleString('en-GB', { month: 'short', timeZone: 'UTC' }).toUpperCase();
const year = date.getUTCFullYear();
---

<div class="border-b border-ink py-3 px-1 font-mono text-xs tracking-widercaps">
  <a href="/events" class="opacity-60 hover:opacity-100">EVENTS</a>
  <span class="opacity-40 mx-1">/</span>
  <span class="opacity-60">{year}</span>
  <span class="opacity-40 mx-1">/</span>
  <span class="opacity-60">{month}</span>
  <span class="opacity-40 mx-1">/</span>
  <span class="text-ink">{title.toUpperCase().slice(0, 40)}</span>
</div>

<header class="py-8 md:py-12">
  <div class="font-mono text-xs tracking-widercaps mb-4 opacity-60 flex items-center gap-2">
    <Glyph kind="circle" size={12} />
    ASSEMBLY — {formatDate(date).toUpperCase()}
  </div>
  <h1 class="text-4xl sm:text-5xl md:text-6xl font-medium tracking-[-0.03em] leading-[0.95] m-0">
    {title}
  </h1>
  {summary && (
    <p class="mt-6 text-base md:text-lg leading-relaxed max-w-2xl text-muted">{summary}</p>
  )}
  {location && (
    <p class="mt-4 font-mono text-xs tracking-widercaps">
      WHERE ·{' '}
      {locationUrl ? (
        <a href={locationUrl} target="_blank" rel="noopener noreferrer" class="underline underline-offset-4">
          {location.toUpperCase()}
        </a>
      ) : location.toUpperCase()}
    </p>
  )}
  {pods.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-6">
      {pods.map((pod) => (
        <a
          href={`/pods/${pod.slug}`}
          class="chip hover:bg-ink hover:text-paper transition-colors"
        >
          ◇ {pod.data.title}
        </a>
      ))}
    </div>
  )}
</header>
