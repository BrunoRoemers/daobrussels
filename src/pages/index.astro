---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Glyph from '../components/marks/Glyph.astro';
import HeroShapes from '../components/ui/HeroShapes.astro';
import CommunityStats from '../components/ui/CommunityStats.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Tabs from '../components/ui/Tabs.astro';
import EventBigCard from '../components/events/EventBigCard.astro';
import PodGrid from '../components/pods/PodGrid.astro';
import {
  getSortedEvents,
  getSortedPods,
  getNextEvent,
  assemblyNumberFor,
  buildPodEventCounts,
  getCommunityCounts,
} from '../lib/content';

const nextEvent = await getNextEvent();
const recentEvents = (await getSortedEvents()).slice(0, 3);
const allPods = await getSortedPods();
const recentPods = allPods.filter((p) => p.data.status === 'active').slice(0, 6);
const podEventCounts = await buildPodEventCounts(recentPods);

const counts = await getCommunityCounts();

// The hero eyebrow shows the latest assembly's number — falls back to total
// events if no past event is registered yet.
const heroAssemblyNo = counts.heldEvents || counts.totalEvents;

// The featured event in the "Next assembly" card carries its own № so the
// card's eyebrow stays in sync with the rest of the site.
const featuredEvent = nextEvent ?? recentEvents[0] ?? null;
const featuredAssemblyNo = featuredEvent ? await assemblyNumberFor(featuredEvent) : 0;

const tabs = [
  { label: 'all', active: true },
  { label: 'tech' },
  { label: 'commons' },
  { label: 'crypto' },
];
---

<BaseLayout title="Manifesto">
  <!-- Hero ------------------------------------------------------------- -->
  <section class="section-x pt-12 md:pt-16 pb-10 md:pb-14">
    <div class="grid gap-10 md:gap-12 md:grid-cols-[1.2fr_1fr] items-start">
      <div>
        <div class="font-mono text-[11px] sm:text-xs tracking-widercaps mb-6 sm:mb-8 opacity-80">
          <span aria-hidden="true">◯</span>{' '}
          ASSEMBLY №{heroAssemblyNo} / COMMONS HUB BRUSSELS / EST. 2021
        </div>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[92px] leading-[0.95] tracking-[-0.04em] font-medium m-0">
          A city,<br />
          <span class="italic font-normal">governed</span><br />
          by its<br />
          citizens.
        </h1>
        <p class="text-base md:text-lg leading-relaxed mt-7 md:mt-8 max-w-lg text-muted">
          We meet the first Wednesday of every month to think out loud about
          commons, cryptography and the slow re&#8209;tooling of
          public life. Workshops, presentations, fermenting things, governance
          by candle&#8209;light.
        </p>
        <div class="flex flex-wrap gap-3 mt-7 md:mt-8">
          {nextEvent ? (
            <a href={`/events/${nextEvent.slug}`} class="btn-ink px-5 py-3.5">JOIN NEXT ASSEMBLY →</a>
          ) : (
            <a href="/events" class="btn-ink px-5 py-3.5">SEE ALL ASSEMBLIES →</a>
          )}
          <a href="/pods" class="btn-ghost px-5 py-3">READ MANIFESTO</a>
        </div>
      </div>

      <div class="hidden md:block">
        <HeroShapes />
      </div>
    </div>
  </section>

  <!-- Stats strip ------------------------------------------------------- -->
  <CommunityStats />

  <!-- Next assembly ----------------------------------------------------- -->
  <section class="section-x section-y">
    <SectionHeading
      glyph="◯"
      label={nextEvent ? 'NEXT ASSEMBLY' : 'LATEST ASSEMBLY'}
      href="/events"
      hrefLabel="ALL EVENTS →"
    />
    {featuredEvent ? (
      <EventBigCard event={featuredEvent} assemblyNo={featuredAssemblyNo} />
    ) : (
      <div class="border-2 border-ink p-8 text-center">
        <Glyph kind="ring" size={64} class="mx-auto mb-3" />
        <p class="font-mono text-sm tracking-widercaps">NO ASSEMBLY SCHEDULED · CHECK BACK SOON</p>
      </div>
    )}
  </section>

  <hr class="hr-thin" />

  <!-- Active pods ------------------------------------------------------- -->
  <section class="section-x section-y">
    <SectionHeading glyph="◇" label="ACTIVE PODS" href="/pods" hrefLabel="ALL PODS →" />
    <Tabs tabs={tabs} class="mb-6" />
    {recentPods.length > 0 ? (
      <PodGrid pods={recentPods} eventCounts={podEventCounts} />
    ) : (
      <p class="font-mono text-sm tracking-widercaps opacity-60">NO PODS YET.</p>
    )}
  </section>
</BaseLayout>
