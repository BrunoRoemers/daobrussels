---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import EventHeader from '../../components/events/EventHeader.astro';
import EventCover from '../../components/events/EventCover.astro';
import EventRsvpCard from '../../components/events/EventRsvpCard.astro';
import CommentFeed from '../../components/nostr/CommentFeed.svelte';
import { getSortedEvents, assemblyNumberFor } from '../../lib/content';

export async function getStaticPaths() {
  const events = await getCollection('events', ({ data }) => !data.draft);
  return events.map((event) => ({ params: { slug: event.slug }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await event.render();

const assemblyNo = await assemblyNumberFor(event);


const allEvents = await getSortedEvents();
const related = allEvents.filter((e) => e.slug !== event.slug).slice(0, 3);
---

<BaseLayout
  title={event.data.title}
  description={event.data.summary}
  ogImage={event.data.images[0]}
>
  <article class="section-x">
    <EventHeader event={event} assemblyNo={assemblyNo} />

    {event.data.images.length > 0 && (
      <EventCover
        images={event.data.images}
        alt={`${event.data.title} — cover photograph`}
        number={assemblyNo}
        caption={event.data.title}
      />
    )}

    <hr class="hr-thick" />

    <!-- Main grid: content + RSVP sidebar -->
    <div class="grid gap-8 md:gap-12 lg:grid-cols-[1fr_360px] py-10 md:py-14">
      <div>
        <div class="prose max-w-none">
          <Content />
        </div>
      </div>

      <EventRsvpCard event={event} />
    </div>

    <hr class="hr-thick" />

    <!-- Comments + sidebar -->
    <div class="grid gap-8 md:gap-12 lg:grid-cols-[1fr_280px] py-10 md:py-14">
      <div>
        <CommentFeed eventTag={event.data.nostrEventTag} client:visible />
      </div>

      <aside>
        {related.length > 0 && (
          <>
            <div class="mono-label opacity-60 mb-3">RELATED ASSEMBLIES</div>
            <div class="border-t border-ink">
              {related.map((e) => (
                <a
                  href={`/events/${e.slug}`}
                  class="flex justify-between gap-3 py-3 border-b border-ink hover:bg-ink hover:text-paper px-2 -mx-2 transition-colors"
                >
                  <div class="text-sm">{e.data.title}</div>
                  <div class="font-mono text-[11px] opacity-60 shrink-0">
                    {e.data.date.toLocaleString('en-GB', { month: 'short', day: '2-digit', timeZone: 'UTC' }).toUpperCase()}
                  </div>
                </a>
              ))}
            </div>
          </>
        )}
      </aside>
    </div>
  </article>
</BaseLayout>
