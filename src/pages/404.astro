---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="max-w-4xl mx-auto px-4 py-24 text-center">
    <p class="text-6xl font-mono font-semibold text-gray-200 mb-4">404</p>
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">Page not found</h1>
    <p class="text-gray-500 mb-8">This page doesn't exist or has been moved.</p>
    <a href="/" class="text-dao-green hover:text-dao-dark underline transition-colors">
      Back to home
    </a>
  </div>
</BaseLayout>
