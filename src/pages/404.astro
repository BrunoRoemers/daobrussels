---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Glyph from '../components/marks/Glyph.astro';
---

<BaseLayout title="Page not found">
  <div class="section-x section-y text-center max-w-2xl mx-auto py-24 md:py-32">
    <div class="flex justify-center mb-8" aria-hidden="true">
      <Glyph kind="ring" size={140} />
    </div>
    <p class="font-mono text-7xl tracking-tight m-0">404</p>
    <h1 class="text-3xl md:text-4xl font-medium mt-6 tracking-tight">Off the grid.</h1>
    <p class="text-muted mt-3 mb-8 leading-relaxed">
      This page doesn't exist or has been dissolved by an assembly.
    </p>
    <a href="/" class="btn-ink px-5 py-3">← BACK TO MANIFESTO</a>
  </div>
</BaseLayout>
